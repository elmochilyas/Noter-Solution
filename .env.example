APP_NAME="Sana Bouhamidi"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://sana.test
APP_LOCALE=ar
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=ar_SA
APP_TIMEZONE=Africa/Casablanca

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database — use Supabase dev project or local Postgres
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=sana_dev
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Redis (local or Hetzner)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null

# Session (stored in Redis for persistence across workers)
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_PATH=/
SESSION_DOMAIN=null

# Queue
QUEUE_CONNECTION=redis
HORIZON_DASHBOARD_USER=admin@example.com

# Cache
CACHE_STORE=redis

# Mail / Resend
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@sana-bouhamidi.ma"
MAIL_FROM_NAME="${APP_NAME}"
RESEND_KEY=

# Stripe (test mode)
STRIPE_KEY=pk_test_xxx
STRIPE_SECRET=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_SMS=Bouhamidi
TWILIO_FROM_WHATSAPP=whatsapp:+14155238886

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Voyage AI (embeddings)
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3-lite

# Supabase Storage (S3-compatible)
SUPABASE_STORAGE_ENDPOINT=
SUPABASE_STORAGE_KEY=
SUPABASE_STORAGE_SECRET=

# Sentry
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0

# Filesystem
FILESYSTEM_DISK=local

# AWS (reserved)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Vite
VITE_APP_NAME="${APP_NAME}"
